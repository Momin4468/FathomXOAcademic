{
  "$comment": "Claude Code permissions for Business OS. allow = runs without asking. deny = always blocked/asks even in auto mode. Anything not listed falls through to 'ask'. Tighten/loosen as you learn what you trust. Syntax: Bash(cmd:*) matches a command and its args; Edit(path) / Read(path) match file globs.",

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(playwright:*)",

      "Bash(npx prisma migrate dev:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npx prisma db push:*)",
      "Bash(npx prisma studio:*)",
      "Bash(npx drizzle-kit generate:*)",
      "Bash(npx drizzle-kit migrate:*)",
      "Bash(npx drizzle-kit push:*)",

      "Bash(docker compose up:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose start:*)",
      "Bash(docker compose stop:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",

      "Bash(ls:*)", "Bash(cat:*)", "Bash(cd:*)", "Bash(pwd:*)",
      "Bash(echo:*)", "Bash(mkdir:*)", "Bash(touch:*)",
      "Bash(grep:*)", "Bash(rg:*)", "Bash(find:*)",
      "Bash(head:*)", "Bash(tail:*)", "Bash(wc:*)", "Bash(which:*)",
      "Bash(cp:*)", "Bash(mv:*)",

      "Read(*)",
      "Edit(src/**)",
      "Edit(app/**)",
      "Edit(apps/**)",
      "Edit(packages/**)",
      "Edit(prisma/**)",
      "Edit(drizzle/**)",
      "Edit(migrations/**)",
      "Edit(test/**)",
      "Edit(tests/**)",
      "Edit(public/**)",
      "Edit(*.json)",
      "Edit(*.ts)",
      "Edit(*.tsx)",
      "Edit(*.js)",
      "Edit(*.md)",
      "Edit(docs/PROGRESS.md)",
      "Edit(docs/DECISIONS.md)"
    ],

    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker system prune:*)",
      "Bash(dropdb:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(npx drizzle-kit drop:*)",
      "Bash(psql:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(npm publish:*)",

      "Edit(CLAUDE.md)",
      "Edit(docs/DESIGN_SPEC.md)",
      "Edit(docs/SCHEMA.md)",
      "Edit(.claude/settings.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(.env)",

      "Edit(reference/**)"
    ]
  }
}
