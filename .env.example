# Copy to .env and fill. Never commit .env.
# -------------------------------------------------------------
# Postgres superuser (migrations/admin only -- owns the schema, can run DDL).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=business_os
POSTGRES_HOST=localhost
# NOTE: host published on 5433 because a local Postgres may occupy 5432.
POSTGRES_PORT=5433

# Admin connection string (migrator/seed run as the owner).
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5433/business_os

# -------------------------------------------------------------
# Application DB role -- NON-superuser, NON-owner, so Postgres RLS is ENFORCED.
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_pw
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5433/business_os

# -------------------------------------------------------------
# API. JWT_SECRET MUST be >= 32 chars or the API refuses to boot. Use a strong
# random value in real deployments (this dev value is intentionally insecure).
PORT=3001
JWT_SECRET=dev-insecure-secret-CHANGE-ME-min-32-chars-0123456789
NODE_ENV=development

# Feature flags (modules opt-in; platform is always on)
FEATURE_REFERENCE=true
FEATURE_WORK=true
FEATURE_RULES=true
FEATURE_BILLING=true
FEATURE_EXPENSES=true
FEATURE_CAPTURE=true
FEATURE_OUTCOMES=true
FEATURE_CREDENTIAL_VAULT=true
FEATURE_KNOWLEDGE=true
FEATURE_REFERRERS=true
FEATURE_DASHBOARD=true
EMAIL_ADAPTER=dev
FEATURE_EXPENSES=true
FEATURE_PERSONAL_FINANCE=true
# Vault encryption key (32 bytes, base64-encoded). Use a strong random value in real deployments.
VAULT_ENCRYPTION_KEY=<paste output of the command below>

# -------------------------------------------------------------
# Analytics / BI (DESIGN_SPEC §8). Metabase reads the DB as this READ-ONLY role,
# which can SELECT only the redacted `analytics` schema (no base tables). See
# docs/METABASE_SETUP.md.
ANALYTICS_RO_USER=analytics_ro
ANALYTICS_RO_PASSWORD=analytics_ro_pw
# Metabase embedding. METABASE_EMBED_SECRET must equal Metabase's
# MB_EMBEDDING_SECRET_KEY, be >= 32 chars, and be DISTINCT from JWT_SECRET.
METABASE_SITE_URL=http://localhost:3000
METABASE_EMBED_SECRET=dev-insecure-metabase-embed-secret-min-32-chars-0123456789
# Numeric dashboard IDs (from Metabase once the dashboards are built).
METABASE_DASHBOARD_OWNER=
METABASE_DASHBOARD_MEMBER=