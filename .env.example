# Copy to .env and fill. Never commit .env.
# -------------------------------------------------------------
# Postgres superuser (migrations/admin only -- owns the schema, can run DDL).
# Used by docker-compose to init the cluster and by the migrator.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=business_os
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Admin connection string (migrator/seed run as the owner).
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5432/business_os

# -------------------------------------------------------------
# Application DB role -- NON-superuser, NON-owner, so Postgres RLS is ENFORCED.
# (Superusers and table owners bypass RLS; the app MUST connect as this role.)
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_pw

# Runtime connection string the API uses (the role above).
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5432/business_os

# -------------------------------------------------------------
# API
PORT=3001
JWT_SECRET=change-me-in-real-deployments
NODE_ENV=development
