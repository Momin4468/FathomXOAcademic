# Copy to .env and fill. Never commit .env.
# =============================================================================
# Master reference for every env var the system reads.
# Loaded by: the API (apps/api) and packages/db (both read THIS repo-root .env),
# and docker-compose. The Next.js apps read their OWN dir's .env — so the
# "Web app" / "Marketing app" sections at the bottom are REFERENCE ONLY; copy
# them into apps/web/.env and apps/marketing/.env (see those .env.example files).
#
# Tags: [REQUIRED] no safe default · [required if X] only when that feature is
#       used · [optional — default Y] safe to omit.
# Minimum to boot API + migrate: DATABASE_URL_ADMIN, DATABASE_URL, JWT_SECRET.
# =============================================================================

# --- Postgres / Docker (docker-compose reads these; also compose the URLs) ---
POSTGRES_USER=postgres                 # [optional — default postgres] superuser/owner
POSTGRES_PASSWORD=postgres             # [optional — default postgres]
POSTGRES_DB=business_os                # [optional — default business_os]
POSTGRES_HOST=localhost                # [optional — default localhost]
POSTGRES_PORT=5433                     # [optional — default 5432 in compose] host port -> container 5432
METABASE_PORT=3000                     # [optional — default 3000] host port for the Metabase container

# --- Database connections (API + migrator/seed) ---
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5433/business_os   # [REQUIRED] owner conn (DDL/migrate/seed, bypasses RLS)
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5433/business_os      # [REQUIRED] app role, RLS ENFORCED
APP_DB_USER=app_user                   # [optional — default app_user]
APP_DB_PASSWORD=app_user_pw            # [optional — default app_user_pw]

# --- API core / secrets ---
PORT=3001                              # [optional — default 3001]
NODE_ENV=development                   # [optional — default development]
JWT_SECRET=dev-insecure-secret-CHANGE-ME-min-32-chars-0123456789               # [REQUIRED] >= 32 chars or API won't boot

# --- Feature flags (FEATURE_<MODULE>; absent/not-"true" = OFF. platform always on) ---
FEATURE_REFERENCE=true
FEATURE_WORK=true
FEATURE_RULES=true
FEATURE_CAPTURE=true
FEATURE_BILLING=true
FEATURE_EXPENSES=true
FEATURE_OUTCOMES=true
FEATURE_CREDENTIAL_VAULT=true          # needs VAULT_ENCRYPTION_KEY
FEATURE_KNOWLEDGE=true
FEATURE_CHECKS=true
FEATURE_REFERRERS=true
FEATURE_CUSTOM_FIELDS=true
FEATURE_DASHBOARD=true                 # needs METABASE_* for the embed endpoint
FEATURE_PERSONAL_FINANCE=true
FEATURE_AI_CAPTURE=true
FEATURE_IMPORT_EXPORT=true
FEATURE_CHANNELS=true
FEATURE_CLIENT_PORTAL=true             # enables the client portal + public quote intake

# --- Email ---
EMAIL_ADAPTER=dev                      # [optional — default dev] dev = log + optional outbox; no real SMTP wired yet
EMAIL_FROM=no-reply@xfactoras.local    # [optional — default no-reply@...] sender address
# EMAIL_OUTBOX_DIR=                    # [optional — default unset] dev adapter writes full messages here (tests use this)

# --- File storage ---
STORAGE_DIR=storage/uploads            # [optional — default storage/uploads]
FILES_MAX_BYTES=10485760               # [optional — default 10485760 = 10 MB]

# --- Crypto (credential vault + sealed 2FA) ---
# 32 bytes base64. Needed at first encrypt/seal; app boots without it but throws on use.
# BACK THIS UP SECURELY — losing it makes the vault permanently unrecoverable.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_ENCRYPTION_KEY=<paste 32-byte base64>   # [required if FEATURE_CREDENTIAL_VAULT or 2FA]

# --- Analytics / BI (Metabase; see docs/METABASE_SETUP.md) ---
ANALYTICS_RO_USER=analytics_ro         # [optional — default analytics_ro]
ANALYTICS_RO_PASSWORD=analytics_ro_pw  # [optional — default analytics_ro_pw]
METABASE_SITE_URL=http://localhost:3000   # [optional — default http://localhost:3000]
METABASE_EMBED_SECRET=dev-insecure-metabase-embed-secret-min-32-chars-0123456789   # [required if FEATURE_DASHBOARD embed] >=32, must equal Metabase MB_EMBEDDING_SECRET_KEY, distinct from JWT_SECRET
METABASE_DASHBOARD_OWNER=              # [required if FEATURE_DASHBOARD embed] numeric dashboard id
METABASE_DASHBOARD_MEMBER=            # [required if FEATURE_DASHBOARD embed] numeric dashboard id

# --- AI capture (§10/§2). Provider swappable; `dev` is the free default. ---
AI_CAPTURE_PROVIDER=dev                # [optional — default dev] dev | gemini | claude
AI_CAPTURE_DAILY_CAP=25                # [optional — default 25] per-user/day cap
# GEMINI_API_KEY=                      # [required if AI_CAPTURE_PROVIDER=gemini]
# GEMINI_MODEL=                        # [optional — provider default]
# ANTHROPIC_API_KEY=                   # [required if AI_CAPTURE_PROVIDER=claude]
# CLAUDE_MODEL=                        # [optional — provider default]

# --- Client portal & public quote intake ---
CLIENT_PORTAL_WHATSAPP=8801XXXXXXXXX   # [optional] wa.me number for the in-portal handoff
CLIENT_LEAD_TTL_DAYS=30                # [optional — default 30] unconverted-lead expiry
PUBLIC_LEAD_ORG_ID=                    # [optional — default seed org] org public quote leads land in
# PUBLIC_QUOTE_NOTIFY_EMAIL=          # [optional — default unset] ops inbox for new quotes
PUBLIC_QUOTE_RATE_MAX=5                # [optional — default 5] per-IP quote submissions per window
PUBLIC_QUOTE_RATE_WINDOW_MS=3600000    # [optional — default 3600000 = 1h]
PUBLIC_QUOTE_GLOBAL_MAX=500            # [optional — default 500] global hourly ceiling
PUBLIC_INTAKE_PROXY_SECRET=            # [required if prod public intake] must equal marketing's; unset in dev = trust XFF

# --- Password reset (all three auth planes) ---
WEB_BASE_URL=http://localhost:3000     # [optional — default http://localhost:3000] base for emailed reset links
PASSWORD_RESET_TTL_MIN=60              # [optional — default 60] token lifetime (min)
PASSWORD_RESET_RATE_MAX=5              # [optional — default 5] request attempts/window (per IP + per identifier)
PASSWORD_RESET_RATE_WINDOW_MS=900000   # [optional — default 900000 = 15m]
PASSWORD_RESET_CONSUME_MAX=20          # [optional — default 20] set-password attempts/IP/window
# --- Login brute-force limits (in-process, best-effort) ---
AUTH_LOGIN_RATE_MAX=10                 # [optional — default 10] login attempts per (IP + email) per window
AUTH_LOGIN_IP_RATE_MAX=50              # [optional — default 50] broader per-IP login attempts per window (credential stuffing)
AUTH_LOGIN_RATE_WINDOW_MS=900000       # [optional — default 900000 = 15m] window for both login limiters
# =============================================================================
# Web app — apps/web/.env (REFERENCE ONLY; Next reads apps/web/.env, not this).
# =============================================================================
# API_URL=http://localhost:3001        # [optional — default http://localhost:3001] server-only BFF target

# =============================================================================
# Marketing app — apps/marketing/.env (REFERENCE ONLY; Next reads that dir).
# =============================================================================
# API_URL=http://localhost:3001              # [optional — default http://localhost:3001] private API base (server-only)
# QUOTE_RATE_MAX=6                           # [optional — default 6] BFF per-IP quote cap
# PUBLIC_INTAKE_PROXY_SECRET=                # [required if prod] must equal the API's value above
# NEXT_PUBLIC_SITE_URL=https://xfactoras.com # [optional — default https://xfactoras.com] (browser-exposed)
# NEXT_PUBLIC_WHATSAPP_NUMBER=8801000000000  # [optional — default 8801000000000] digits only (browser-exposed)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@xfactoras.com  # [optional — default hello@xfactoras.com] (browser-exposed)