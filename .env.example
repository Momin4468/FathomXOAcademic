# Copy to .env and fill. Never commit .env.
# -------------------------------------------------------------
# Postgres superuser (migrations/admin only -- owns the schema, can run DDL).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=business_os
POSTGRES_HOST=localhost
# NOTE: host published on 5433 because a local Postgres may occupy 5432.
POSTGRES_PORT=5433

# Admin connection string (migrator/seed run as the owner).
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5433/business_os

# -------------------------------------------------------------
# Application DB role -- NON-superuser, NON-owner, so Postgres RLS is ENFORCED.
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_pw
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5433/business_os

# -------------------------------------------------------------
# API. JWT_SECRET MUST be >= 32 chars or the API refuses to boot. Use a strong
# random value in real deployments (this dev value is intentionally insecure).
PORT=3001
JWT_SECRET=dev-insecure-secret-CHANGE-ME-min-32-chars-0123456789
NODE_ENV=development

# Feature flags (modules opt-in; platform is always on)
FEATURE_REFERENCE=true
FEATURE_WORK=true
FEATURE_RULES=true
FEATURE_BILLING=true
FEATURE_EXPENSES=true
FEATURE_CAPTURE=true
