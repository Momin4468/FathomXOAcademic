# Copy to .env (or .env.local). Next.js loads THIS directory's .env — the
# repo-root .env is NOT read by this app. Never commit .env.
API_URL=http://localhost:3001                  # [optional — default http://localhost:3001] private API base (server-only; never reaches the browser)
QUOTE_RATE_MAX=6                               # [optional — default 6] best-effort per-IP quote cap at the BFF (API is authoritative)
PUBLIC_INTAKE_PROXY_SECRET=                     # [required if prod] must equal the API's PUBLIC_INTAKE_PROXY_SECRET; unset in dev = API trusts XFF
NEXT_PUBLIC_SITE_URL=https://xfactoras.com      # [optional — default https://xfactoras.com] canonical public URL (browser-exposed)
NEXT_PUBLIC_WHATSAPP_NUMBER=8801000000000       # [optional — default 8801000000000] intl format, digits only (browser-exposed)
NEXT_PUBLIC_CONTACT_EMAIL=hello@xfactoras.com   # [optional — default hello@xfactoras.com] (browser-exposed)